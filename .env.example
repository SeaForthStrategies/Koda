# Supabase (auth + database)
# Get both from: Supabase Dashboard → Project Settings → API
# Project URL = your project’s API URL (e.g. https://xxxx.supabase.co)
# anon public = the anon public key (safe to use in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Employer access: comma-separated emails that can log in as Employer and see /admin
# Optional. If unset, only users with role=employer in profiles (e.g. set in DB) can access admin.
EMPLOYER_EMAILS=admin@company.com

# Resend (time card emails – https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=timecards@yourdomain.com

# Stripe (billing – https://stripe.com)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRICE_ID_PRO=price_xxxxxxxxxxxx
