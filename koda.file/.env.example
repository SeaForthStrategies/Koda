# ─────────────────────────────────────────────
# Koda Time Tracking — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── SMTP Email Configuration ──────────────────
# For Gmail: use App Passwords (https://myaccount.google.com/apppasswords)
# For SendGrid: host=smtp.sendgrid.net, user=apikey, pass=YOUR_API_KEY
# For Resend: host=smtp.resend.com, user=resend, pass=YOUR_API_KEY

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@yourdomain.com

# ── Authentication (replace with real auth in production) ──
# Using NextAuth, Clerk, or Auth0 is strongly recommended
# for production deployments.
NEXTAUTH_SECRET=change-me-to-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# ── Cloudflare Turnstile (optional — alternative to honeypot) ──
# Get keys at: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
